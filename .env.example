# ═══════════════════════════════════════════════════════════════
#  XERON ENGINE v7 — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to git!
# ═══════════════════════════════════════════════════════════════

# SUPABASE — supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR-SERVICE-KEY

# ANTHROPIC — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY

# GOOGLE GEMINI — aistudio.google.com → Get API Key
GOOGLE_GEMINI_API_KEY=AIzaSy-YOUR-KEY

# STRIPE — dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_YOUR-STRIPE-SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR-STRIPE-PUBLIC
STRIPE_WEBHOOK_SECRET=whsec_YOUR-WEBHOOK-SECRET

# STRIPE PRICE IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_STARTER_MONTHLY
STRIPE_PRICE_STARTER_YEARLY=price_STARTER_YEARLY
STRIPE_PRICE_PRO_MONTHLY=price_PRO_MONTHLY
STRIPE_PRICE_PRO_YEARLY=price_PRO_YEARLY
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_ENTERPRISE_MONTHLY
STRIPE_PRICE_ENTERPRISE_YEARLY=price_ENTERPRISE_YEARLY
STRIPE_PRICE_CREDITS_MINI=price_CREDITS_50
STRIPE_PRICE_CREDITS_STARTER=price_CREDITS_150
STRIPE_PRICE_CREDITS_VALUE=price_CREDITS_400
STRIPE_PRICE_CREDITS_POWER=price_CREDITS_1000
STRIPE_PRICE_CREDITS_MEGA=price_CREDITS_3000

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ADMIN — for /api/admin/* routes
ADMIN_SECRET=YOUR-SECURE-ADMIN-SECRET-MIN-32-CHARS

# ═══════════════════════════════════════════════════════════════
#  COUPON CODES — STRICTLY SECRET — NEVER in Git or DB!
#  Validation happens server-side ONLY
# ═══════════════════════════════════════════════════════════════
COUPON_1=YOUR-CODE-1   # 5% discount on Pro+Enterprise
COUPON_2=YOUR-CODE-2   # 10 credits
COUPON_3=YOUR-CODE-3   # 20 credits
COUPON_4=YOUR-CODE-4   # 30% discount on all plans
COUPON_5=YOUR-CODE-5   # DEVELOPER: Enterprise free + 8999 credits
COUPON_6=YOUR-CODE-6   # DEVELOPER: Pro free + 400 credits
COUPON_7=YOUR-CODE-7   # 100 credits
